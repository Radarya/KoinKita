rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Aturan untuk Users
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // 2. Aturan untuk Kotak Masuk (Inbox)
    match /inbox/{messageId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // 3. Aturan untuk Klub Finansial
    match /clubs/{clubId} {
      allow read, write: if request.auth != null;
    }

    // 4. Aturan untuk League Groups (Sistem Liga)
    match /league_groups/{groupId} {
      // Mengizinkan user yang login untuk read dan update skor liga di grup mereka
      allow read, write: if request.auth != null;
    }

    // Default rule: tolak akses ke koleksi lain yang tidak didefinisikan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
